
FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src


COPY Insights.Services.CountriesAPI/Insights.Services.CountriesAPI.csproj Insights.Services.CountriesAPI/
COPY Insights.SharedKernel/Insights.SharedKernel.csproj Insights.SharedKernel/



RUN dotnet restore Insights.Services.CountriesAPI/Insights.Services.CountriesAPI.csproj

COPY Insights.Services.CountriesAPI/ Insights.Services.CountriesAPI/
COPY Insights.SharedKernel/ Insights.SharedKernel/


RUN dotnet publish Insights.Services.CountriesAPI/Insights.Services.CountriesAPI.csproj \
    --no-restore \
    --configuration Release \
    --output /app/publish

FROM mcr.microsoft.com/dotnet/aspnet:8.0 AS runtime
WORKDIR /app

COPY --from=build /app/publish .

EXPOSE 8080
ENTRYPOINT ["dotnet", "Insights.Services.CountriesAPI.dll"]