{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "InsightsDb": "Host=localhost;Database=insights;Username=postgres;Password=postgres"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "guest",
    "Password": "guest",
    "ExchangeName": "geo-exchange",
    "ExchangeType": "topic"
  },
  "AllowedHosts": "*",
  "ApiInfo": {
    "Auth": { 
      "AuthApiUrl": "https://localhost:7241"
    },
    "Countries": {
      "Name": "CountriesAPI",
      "BaseUrl": "https://localhost:7001",
      "Endpoints": {
        "GetCountryByCode": "/api/countries/##COUNTRY##"
      }
    },
    "Cities": {
      "Name": "CitiesAPI",
      "BaseUrl": "https://localhost:7002",
      "Endpoints": {
        "GetCitiesByName": "/api/cities/##CITY##",
        "GetCitiesByCoordinates": "/api/cities/coordinates?lat=##LAT##&lon=##LON##",
        "GetCityByIPAddress": "/api/cities/iplookup?ipAddress=##IP_ADDRESS##"
      }
    },
    "Weather": {
      "Name": "WeatherAPI",
      "BaseUrl": "https://localhost:7003",
      "Endpoints": {
        "GetWeatherByLocation": "/api/weather?lon=##LON##&lat=##LAT##"
      }

    }
  },
  "TopicAndQueueNames": {
    "EmailWeatherInfo": "emailweatherinfo"
  }
}
