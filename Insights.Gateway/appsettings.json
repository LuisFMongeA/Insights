{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
    "AllowedHosts": "*",
  "ApiInfo": {
    "Countries": {
      "Name": "CountriesAPI",
      "BaseUrl": "https://localhost:7001/api",
      "Endpoints": {
        "GetCountryByCode": "/countries/##COUNTRY##"
      }
    },
    "Cities": {
      "Name": "CitiesAPI",
      "BaseUrl": "https://localhost:7002/api",
      "Endpoints": {
        "GetCitiesByName": "/cities/##CITY##",
        "GetCitiesByCoordinates": "/cities/coordinates?lat=##LAT##&lon=##LON##"
      }
    },
    "Weather": {
      "Name": "WeatherAPI",
      "BaseUrl": "https://localhost:7003/api",
      "Endpoints": {
        "GetWeatherByLocation": "/weather?lon=##LON##&lat=##LAT##"
      }

    },
    "Nats": {
      "Url": "nats://localhost:4222"
    }
  },
    "TopicAndQueueNames": {
        "EmailWeatherInfo": "emailweatherinfo"
    }
}
